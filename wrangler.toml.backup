name = "ghostreceipt-oracle"
main = "workers/oracle.ts"
compatibility_date = "2024-03-21"
account_id = "8f49c311ff2506c6020f060b8c1da686"

# KV Namespaces for caching
[[kv_namespaces]]
binding = "CACHE"
id = ""  # Will be created with: wrangler kv:namespace create CACHE

# Environment variables (secrets set via: wrangler secret put <KEY>)
[vars]
ENVIRONMENT = "development"

# Production environment
[env.production]
name = "ghostreceipt-oracle-production"
vars = { ENVIRONMENT = "production" }

[[env.production.kv_namespaces]]
binding = "CACHE"
id = ""  # Will be created with: wrangler kv:namespace create CACHE --env production

# Staging environment
[env.staging]
name = "ghostreceipt-oracle-staging"
vars = { ENVIRONMENT = "staging" }

[[env.staging.kv_namespaces]]
binding = "CACHE"
id = ""  # Will be created with: wrangler kv:namespace create CACHE --env staging

# Build configuration
[build]
command = "npm run build:worker"

# Observability
[observability]
enabled = true

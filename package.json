{
  "name": "ghostreceipt",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "precommit": "npm test && npm run lint",
    "prepush": "npm run ci:quality-gate",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "check:oracle-transparency-log": "node scripts/check-oracle-transparency-log.mjs",
    "check:zk-artifact-checksums": "node scripts/check-zk-artifact-checksums.mjs",
    "check:release-readiness": "node scripts/check-release-readiness.mjs",
    "export:solidity-verifier": "node scripts/export-solidity-verifier.mjs",
    "check:solidity-verifier": "node scripts/check-solidity-verifier.mjs",
    "test:live:oracle": "bash scripts/run-live-oracle-tests.sh",
    "test:drill:oracle-failover": "bash scripts/run-oracle-failover-drill.sh",
    "test:live:speed:legacy-vs-edge": "SPEED_COMPARE=1 jest tests/integration/live-legacy-vs-edge-speed.test.ts --runInBand --ci --testTimeout=300000 --forceExit",
    "test:live:speed:matrix": "SPEED_COMPARE_MATRIX=1 jest tests/integration/live-legacy-vs-edge-speed-matrix.test.ts --runInBand --ci --testTimeout=420000 --forceExit",
    "test:live:consensus": "LIVE_INTEGRATION=1 jest tests/integration/live-consensus-flows.test.ts --runInBand --ci --testTimeout=240000 --forceExit",
    "test:live:btc:blockcypher": "LIVE_INTEGRATION=1 jest tests/integration/live-bitcoin-blockcypher-e2e.test.ts --runInBand --ci --testTimeout=180000",
    "test:live:solana": "LIVE_INTEGRATION=1 jest tests/integration/live-solana-e2e.test.ts --runInBand --ci --testTimeout=180000",
    "test:stress:oracle": "STRESS_TEST=1 ORACLE_FETCH_TX_CLIENT_MAX_REQUESTS_PER_MINUTE=300 ORACLE_FETCH_TX_GLOBAL_MAX_REQUESTS_PER_MINUTE=1200 ORACLE_FETCH_TX_CLIENT_MAX_REQUESTS_PER_SECOND=30 ORACLE_FETCH_TX_GLOBAL_MAX_REQUESTS_PER_SECOND=600 ORACLE_VERIFY_CLIENT_MAX_REQUESTS_PER_MINUTE=300 ORACLE_VERIFY_GLOBAL_MAX_REQUESTS_PER_MINUTE=1200 ORACLE_VERIFY_CLIENT_MAX_REQUESTS_PER_SECOND=30 ORACLE_VERIFY_GLOBAL_MAX_REQUESTS_PER_SECOND=600 jest tests/integration/stress-oracle-volume.test.ts --runInBand --ci --testTimeout=180000",
    "test:perf:proof": "PROOF_PERF_TEST=1 PROOF_PERF_ITERATIONS=2 PROOF_PERF_WARMUP_ITERATIONS=1 PROOF_PERF_TOTAL_P50_BUDGET_MS=25000 PROOF_PERF_PROVE_P50_BUDGET_MS=25000 PROOF_PERF_VERIFY_P50_BUDGET_MS=2500 PROOF_PERF_WITNESS_P50_BUDGET_MS=250 PROOF_PERF_TOTAL_P95_BUDGET_MS=60000 PROOF_PERF_PROVE_P95_BUDGET_MS=60000 PROOF_PERF_VERIFY_P95_BUDGET_MS=5000 PROOF_PERF_WITNESS_P95_BUDGET_MS=500 jest tests/integration/proof-performance-budget.test.ts --runInBand --ci --testTimeout=300000 --forceExit",
    "test:gate:privacy": "jest tests/unit/policy/advanced-privacy-benchmark-gate.test.ts --runInBand --ci",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check:secrets": "bash scripts/check-secrets.sh",
    "compile:circuit": "bash scripts/compile-circuit.sh",
    "deploy:check": "bash scripts/deploy-check.sh",
    "security:audit": "bash scripts/security-audit.sh",
    "deploy": "bash deploy.sh",
    "deploy:preview": "npm run build && npx wrangler pages deploy out --project-name=ghostreceipt --branch=preview",
    "github:protect-main": "bash scripts/enforce-branch-protection.sh",
    "pages:dev": "npx wrangler pages dev out",
    "cf:setup": "bash scripts/setup-cloudflare.sh",
    "cf:secrets": "bash scripts/manage-secrets.sh",
    "cf:sync": "bash scripts/sync-secrets.sh",
    "ci:quality-gate": "npm run check:secrets && npm run check:oracle-transparency-log && npm run check:solidity-verifier && npm run typecheck && npm run lint && npm run test:coverage && npm run test:perf:proof && npm run test:stress:oracle && npm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@tanstack/react-query": "^5.62.11",
    "circomlibjs": "^0.1.7",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "next": "^16.2.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "snarkjs": "^0.7.5",
    "three": "^0.160.0",
    "viem": "^2.21.54",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.2",
    "@types/snarkjs": "^0.7.9",
    "@types/three": "^0.183.1",
    "autoprefixer": "^10.4.20",
    "husky": "^9.0.0",
    "circomlib": "^2.0.5",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.2.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-environment-node": "^29.7.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2",
    "wrangler": "^4.76.0"
  },
  "overrides": {
    "underscore": "1.13.8"
  },
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=9.0.0"
  }
}

# GhostReceipt Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# PUBLIC VARIABLES (exposed to client)
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GhostReceipt

# ============================================
# ORACLE API KEYS (server-side only)
# ============================================

# Etherscan API Keys (managed, server-side)
# Multiple keys for cascade/rotation
ETHERSCAN_API_KEY_1=your_primary_etherscan_key
ETHERSCAN_API_KEY_2=your_fallback_key_1
ETHERSCAN_API_KEY_3=your_fallback_key_2

# Blockchair API Key (optional, for BTC fallback)
BLOCKCHAIR_API_KEY=

# ============================================
# ORACLE SIGNING (server-side only)
# ============================================

# Oracle private key for signing canonical payloads
# Generate with: openssl rand -hex 32
ORACLE_PRIVATE_KEY=

# ============================================
# OPTIONAL: CLOUDFLARE (for production)
# ============================================

# Cloudflare Workers KV namespace ID
CLOUDFLARE_KV_NAMESPACE_ID=

# Cloudflare account ID
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare API token
CLOUDFLARE_API_TOKEN=

# ============================================
# DEVELOPMENT
# ============================================

# Enable debug logging
DEBUG=false

# Log level (error, warn, info, debug)
LOG_LEVEL=info

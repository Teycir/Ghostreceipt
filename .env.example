# GhostReceipt Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# PUBLIC VARIABLES (exposed to client)
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GhostReceipt

# ============================================
# ORACLE API KEYS (server-side only)
# ============================================

# Etherscan API Keys (managed, server-side)
# Rolling cascade supports ETHERSCAN_API_KEY + _1.._6
ETHERSCAN_API_KEY=your_primary_etherscan_key
ETHERSCAN_API_KEY_1=your_fallback_key_1
ETHERSCAN_API_KEY_2=your_fallback_key_2
ETHERSCAN_API_KEY_3=your_fallback_key_3
ETHERSCAN_API_KEY_4=
ETHERSCAN_API_KEY_5=
ETHERSCAN_API_KEY_6=

# Helius API Keys (managed, server-side)
# Rolling cascade supports HELIUS_API_KEY + _1.._6
HELIUS_API_KEY=your_primary_helius_key
HELIUS_API_KEY_1=your_fallback_helius_key_1
HELIUS_API_KEY_2=your_fallback_helius_key_2
HELIUS_API_KEY_3=
HELIUS_API_KEY_4=
HELIUS_API_KEY_5=
HELIUS_API_KEY_6=

# BlockCypher API Tokens (optional, server-side)
# BTC fallback works keyless, but token cascade improves burst handling.
# Loader supports BLOCKCYPHER_API_TOKEN + _1.._6
BLOCKCYPHER_API_TOKEN=
BLOCKCYPHER_API_TOKEN_1=
BLOCKCYPHER_API_TOKEN_2=
BLOCKCYPHER_API_TOKEN_3=
BLOCKCYPHER_API_TOKEN_4=
BLOCKCYPHER_API_TOKEN_5=
BLOCKCYPHER_API_TOKEN_6=

# Optional public consensus sources (used for peer verification labels)
ETHEREUM_PUBLIC_RPC_URL=https://cloudflare-eth.com
SOLANA_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com

# ============================================
# ORACLE SIGNING (server-side only)
# ============================================

# Oracle private key for signing canonical payloads
# Generate with: openssl rand -hex 32
ORACLE_PRIVATE_KEY=

# Optional oracle public key for verification-only environments
# Derive from private key during deployment and set where private signing key is unavailable.
ORACLE_PUBLIC_KEY=

# Trust upstream proxy IP headers (cf-connecting-ip / true-client-ip / x-real-ip / x-forwarded-for)
# Cloudflare/proxied deployments: set to true.
# Direct Node exposure without a trusted reverse proxy: set to false.
# Note: current replay/rate-limit controls are in-memory and instance-local.
# In serverless/multi-instance deployments, use shared coordination (Durable Objects/KV/Redis) for strict global enforcement.
TRUST_PROXY_HEADERS=true

# ============================================
# ORACLE RATE LIMITS + FETCH CACHE (optional)
# ============================================

# Keep these at conservative defaults for free-tier safety; override only when needed.
ORACLE_FETCH_TX_CLIENT_MAX_REQUESTS_PER_MINUTE=6
ORACLE_FETCH_TX_GLOBAL_MAX_REQUESTS_PER_MINUTE=60
ORACLE_FETCH_TX_CLIENT_MAX_REQUESTS_PER_SECOND=2
ORACLE_FETCH_TX_GLOBAL_MAX_REQUESTS_PER_SECOND=12

ORACLE_VERIFY_CLIENT_MAX_REQUESTS_PER_MINUTE=12
ORACLE_VERIFY_GLOBAL_MAX_REQUESTS_PER_MINUTE=120
ORACLE_VERIFY_CLIENT_MAX_REQUESTS_PER_SECOND=3
ORACLE_VERIFY_GLOBAL_MAX_REQUESTS_PER_SECOND=30

ORACLE_NULLIFIER_CLIENT_MAX_REQUESTS_PER_MINUTE=15
ORACLE_NULLIFIER_GLOBAL_MAX_REQUESTS_PER_MINUTE=150
ORACLE_NULLIFIER_CLIENT_MAX_REQUESTS_PER_SECOND=4
ORACLE_NULLIFIER_GLOBAL_MAX_REQUESTS_PER_SECOND=40

# Canonical transaction cache TTL (milliseconds) for burst smoothing on duplicate tx fetches.
# Set to 0 to disable cache.
ORACLE_FETCH_TX_CANONICAL_CACHE_TTL_MS=15000

# Consensus hardening mode (best-effort by default in non-test):
# - best_effort: try dual-source consensus; if peer source is unavailable, sign with primary and label fallback.
# - strict: require peer consensus and fail-closed on unavailability.
# - off: disable peer-consensus checks.
ORACLE_BTC_CONSENSUS_MODE=best_effort
ORACLE_ETH_CONSENSUS_MODE=best_effort
ORACLE_SOL_CONSENSUS_MODE=best_effort

# ============================================
# OPTIONAL: CLOUDFLARE (for production)
# ============================================

# Cloudflare Workers KV namespace ID
CLOUDFLARE_KV_NAMESPACE_ID=

# Cloudflare account ID
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare API token
CLOUDFLARE_API_TOKEN=

# ============================================
# DEVELOPMENT
# ============================================

# Enable debug logging
DEBUG=false

# Log level (error, warn, info, debug)
LOG_LEVEL=info

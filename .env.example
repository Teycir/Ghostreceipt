# Copy to .env.local and fill with your own keys
# Primary key
ETHERSCAN_API_KEY=your_primary_etherscan_key

# Optional fallback keys for cascade retry
ETHERSCAN_API_KEY_TEYCIRCODER1=your_fallback_key_1
ETHERSCAN_API_KEY_TEYCIRCODER2=your_fallback_key_2
ETHERSCAN_API_KEY_XINGYANG1=your_fallback_key_3
ETHERSCAN_API_KEY_XINGYANG2=your_fallback_key_4
ETHERSCAN_API_KEY_XINGYANG3=your_fallback_key_5
